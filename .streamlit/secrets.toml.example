# Copy to secrets.toml for local Streamlit runs (do not commit secrets.toml).
# On Streamlit Cloud, paste this into App → Settings → Secrets.

GROQ_API_KEY = "gsk_your-key-here"
GROQ_MODEL = "llama-3.3-70b-versatile"
GROQ_BASE_URL = "https://api.groq.com/openai/v1"

# Optional: faster HuggingFace dataset downloads
# HF_TOKEN = "hf_your-token-here"
